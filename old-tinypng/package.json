{
  "name": "tinypngapp",
  "version": "0.0.7",
  "description": "tinyPNG Desktop App",
  "main": "index.js",
  "dependencies": {
    "bootstrap": "^4.1.3",
    "electron-settings": "^3.2.0",
    "jquery": "^3.3.1",
    "popper.js": "^1.14.6",
    "request": "^2.88.0",
    "tinify": "^1.6.0-beta.2"
  },
  "devDependencies": {
    "electron": "^3.0.11",
    "electron-packager": "^13.0.0"
  },
  "scripts": {
    "start": "electron .",
    "package-mac": "electron-packager . --overwrite --platform=darwin --arch=x64 --asars --icon=assets/icons/mac/icon.icns --prune=true --out=release-builds",
    "package-linux": "electron-packager . --overwrite --platform=linux --arch=x64 --asar --icon=assets/icons/icon.png --prune=true --out=release-builds",
    "package-win": "electron-packager . tinyPNGApp --overwrite --platform=win32 --asar --arch=ia32 --icon=assets/icons/win/icon.ico --prune=true --out=release-builds --version-string.CompanyName=BetweenElements --version-string.FileDescription=tinyPNGApp --version-string.ProductName=\"tinyPNGApp\"",
    "package-win64": "electron-packager . tinyPNGApp --overwrite --platform=win32 --asar --arch=x64 --icon=assets/icons/win/icon.ico --prune=true --out=release-builds --version-string.CompanyName=BetweenElements --version-string.FileDescription=tinyPNGApp --version-string.ProductName=\"tinyPNGApp\""
  },
  "repository": {
    "type": "git",
    "url": "tinyPNGApp"
  },
  "author": "BetweenElements",
  "license": "ISC"
}
